{
    "manifest_version":  3,
    "name":  "Backlink Helper Quota Clean",
    "version":  "1.1.1",
    "description":  "Free users can use the first 50 external links without usage counting; license unlocks all links.",
    "permissions":  [
                        "activeTab",
                        "storage",
                        "sidePanel",
                        "scripting"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "action":  {
                   "default_title":  "Backlink Helper Quota Clean"
               },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "side_panel":  {
                       "default_path":  "popup.html"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "content.js"
                                       ]
                            }
                        ],
    "options_ui":  {
                       "page":  "settings.html",
                       "open_in_tab":  true
                   }
}